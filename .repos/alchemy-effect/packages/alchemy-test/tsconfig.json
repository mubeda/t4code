{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "outDir": "./lib",
    "rootDir": "./src",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "lib": ["ESNext"]
  }
}
