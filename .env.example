# Optional: T4 Connect source builds
# Leave these unset to disable optional T4 Connect features in local source builds.
# Release builds inject their public values at build time. Do not add server-side
# secrets to this file.

# Get these from the Clerk Dashboard under API keys, JWT templates, and OAuth applications.
# T4CODE_CLERK_PUBLISHABLE_KEY=pk_test_...
# T4CODE_CLERK_JWT_TEMPLATE=t4code-relay
# T4CODE_CLERK_CLI_OAUTH_CLIENT_ID=oauthapp_...

# Optional: signed macOS passkey builds. The RP domain defaults to the Frontend API
# hostname encoded in T4CODE_CLERK_PUBLISHABLE_KEY. Set the override only when Clerk
# returns a different RP ID or when multiple domains must be entitled.
# T4CODE_APPLE_TEAM_ID=ABC1234567
# T4CODE_MACOS_PROVISIONING_PROFILE=/absolute/path/to/t4code.provisionprofile
# T4CODE_CLERK_PASSKEY_RP_DOMAINS=example.clerk.accounts.dev,clerk.example.com

# Get this from your relay deployment. `infra/relay` deploys update it automatically.
# T4CODE_RELAY_URL=https://relay.example.com

# Public, ingest-only mobile OpenTelemetry configuration.
# T4CODE_MOBILE_OTLP_TRACES_URL=https://api.axiom.co/v1/traces
# T4CODE_MOBILE_OTLP_TRACES_DATASET=t4code-mobile-traces-dev
# T4CODE_MOBILE_OTLP_TRACES_TOKEN=xaat-...
