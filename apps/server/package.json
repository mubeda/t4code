{
  "name": "t4code",
  "version": "0.2.10",
  "private": true,
  "scripts": {
    "build": "node ../../scripts/run-msvc-x64.mjs cargo build -p t4code-server",
    "dev": "node ../../scripts/run-msvc-x64.mjs cargo run -p t4code-server --bin t4code -- serve --no-browser",
    "start": "node ../../scripts/run-msvc-x64.mjs cargo run -p t4code-server --bin t4code --",
    "test": "node ../../scripts/run-msvc-x64.mjs cargo test -p t4code-server -j 2 -- --test-threads=1",
    "typecheck": "node ../../scripts/run-msvc-x64.mjs cargo check -p t4code-server --all-targets"
  }
}
